# Copy to .env and fill in. Never commit the real .env.
OPENAI_API_KEY=

# Model overrides (optional). Defaults are set in pipeline code.
# During development, set DEEP_RESEARCH_MODEL=o4-mini-deep-research to cut cost/latency.
EXTRACTION_MODEL=gpt-4o
DEEP_RESEARCH_MODEL=o3-deep-research
CROSSCHECK_MODEL=o4-mini
SYNTHESIS_MODEL=o3

# Valyu DeepResearch powers Agent A (company internet research). Leave VALYU_API_KEY
# empty to fall back to the OpenAI web-search agent.
VALYU_API_KEY=
VALYU_DR_MODE=fast

# Comma-separated origins allowed by CORS (frontend dev server).
FRONTEND_ORIGIN=http://localhost:3000
